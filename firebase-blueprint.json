{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Hospital staff profile with role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "IPCN", "PHYSICIAN", "PHARMACY", "APPROVER"] },
        "unit": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Audit": {
      "title": "IPC Audit",
      "description": "General audit record for HH, PPE, Safe Injections, etc.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["HH_AVAILABILITY", "HH_COMPLIANCE", "PPE_AVAILABILITY", "PPE_COMPLIANCE", "SAFE_INJECTION", "ENV_CLEANING"] },
        "unit": { "type": "string" },
        "auditorId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "data": { "type": "object" },
        "score": { "type": "number" },
        "total": { "type": "number" }
      },
      "required": ["type", "unit", "auditorId", "timestamp"]
    },
    "NSIReport": {
      "title": "Needle Stick Injury Report",
      "description": "Occupational exposure reporting for staff.",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "reporterEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDING", "VALIDATED", "NOT_NSI", "NEEDS_MORE_DATA"] },
        "incident": {
          "type": "object",
          "properties": {
            "date": { "type": "string", "format": "date" },
            "time": { "type": "string" },
            "unit": { "type": "string" },
            "exposureType": { "type": "string" },
            "deviceInvolved": { "type": "string" },
            "activity": { "type": "string" }
          }
        },
        "staff": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "position": { "type": "string" },
            "employmentStatus": { "type": "string" },
            "hepBStatus": { "type": "string" }
          }
        },
        "source": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "hospNo": { "type": "string" },
            "diagnosis": { "type": "string" },
            "risks": { "type": "array", "items": { "type": "string" } }
          }
        },
        "description": {
          "type": "object",
          "properties": {
            "narrative": { "type": "string" },
            "ppeWorn": { "type": "boolean" },
            "properDisposal": { "type": "boolean" },
            "safetyDeviceActivated": { "type": "string" }
          }
        },
        "actions": {
          "type": "object",
          "properties": {
            "firstAid": { "type": "array", "items": { "type": "string" } },
            "reportedTo": { "type": "array", "items": { "type": "string" } },
            "pep": { "type": "string" }
          }
        },
        "validation": {
          "type": "object",
          "properties": {
            "classification": { "type": "string" },
            "rootCauses": { "type": "array", "items": { "type": "string" } },
            "contributingFactors": { "type": "array", "items": { "type": "string" } },
            "decision": { "type": "string" },
            "correctiveActions": { "type": "array", "items": { "type": "string" } },
            "validatorName": { "type": "string" },
            "validatorId": { "type": "string" },
            "validatedAt": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["reporterId", "createdAt", "status", "incident", "staff", "description", "actions"]
    },
    "AMSRequest": {
      "title": "Antimicrobial Stewardship Request",
      "description": "Request for restricted antibiotic use or 7-day extension.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["RESTRICTED_USE", "EXTENSION_7D"] },
        "patientName": { "type": "string" },
        "hospNo": { "type": "string" },
        "unit": { "type": "string" },
        "antibiotic": { "type": "string" },
        "dose": { "type": "string" },
        "diagnosis": { "type": "string" },
        "justification": { "type": "string" },
        "prescriberId": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "DENIED", "OVERRIDDEN"] },
        "reviewerId": { "type": "string" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "remarks": { "type": "string" },
        "manualApproval": { "type": "boolean" },
        "overrideReason": { "type": "string" }
      },
      "required": ["type", "patientName", "antibiotic", "prescriberId", "status"]
    },
    "HAICase": {
      "title": "HAI Case Report",
      "description": "Surveillance report for CLABSI, VAP, CAUTI, SSI.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["CLABSI", "VAP", "CAUTI", "SSI"] },
        "patientName": { "type": "string" },
        "hospNo": { "type": "string" },
        "unit": { "type": "string" },
        "admissionDate": { "type": "string", "format": "date" },
        "deviceInsertionDate": { "type": "string", "format": "date" },
        "symptoms": { "type": "string" },
        "cultureDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["SUSPECTED", "CONFIRMED", "DISCARDED"] },
        "validatedBy": { "type": "string" },
        "validatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "patientName", "hospNo", "unit", "status"]
    },
    "BOCLog": {
      "title": "Bundle of Care Log",
      "description": "Daily monitoring of care bundles.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "unit": { "type": "string" },
        "patientName": { "type": "string" },
        "deviceType": { "type": "string", "enum": ["CENTRAL_LINE", "VENTILATOR", "FOLEY", "SURGICAL_SITE"] },
        "bundleElements": { "type": "object" },
        "isCompliant": { "type": "boolean" },
        "staffId": { "type": "string" },
        "validatedBy": { "type": "string" }
      },
      "required": ["date", "unit", "patientName", "deviceType", "isCompliant"]
    },
    "OutbreakReport": {
      "title": "Outbreak Report",
      "description": "Reporting and tracking of infectious outbreaks within the facility.",
      "type": "object",
      "properties": {
        "detectedAt": { "type": "string", "format": "date" },
        "detectedTime": { "type": "string" },
        "reportedBy": { "type": "string" },
        "reportingSrc": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Suspected", "Under Investigation", "Confirmed", "Controlled", "Closed"] },
        "reporterId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["detectedAt", "reportedBy", "status", "reporterId", "createdAt"]
    },
    "UserRole": {
      "title": "User Role Definition",
      "description": "Hybrid login role mapping (Email for Admin/Validator, PIN for Ward Staff).",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "staffCode": { "type": "string" },
        "pin": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "IPCN", "PHYSICIAN", "PHARMACY", "APPROVER", "USER"] },
        "unit": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles collection."
    },
    "user_roles": {
      "schema": "UserRole",
      "description": "Central mapping for roles, emails, and PINs."
    },
    "audits": {
      "schema": "Audit",
      "description": "IPC audits collection."
    },
    "nsi_reports": {
      "schema": "NSIReport",
      "description": "Needle stick injury reports."
    },
    "ams_requests": {
      "schema": "AMSRequest",
      "description": "Antimicrobial stewardship requests."
    },
    "hai_cases": {
      "schema": "HAICase",
      "description": "Healthcare-associated infections cases."
    },
    "boc_logs": {
      "schema": "BOCLog",
      "description": "Daily bundle of care compliance logs."
    },
    "outbreaks": {
      "schema": "OutbreakReport",
      "description": "Outbreak detection and management reports."
    }
  }
}
